# Dependencies
node_modules/

# Build outputs
# NOTE: keep these anchored. A bare `lib/` also matches `packages/ui/src/lib/`
# (the library's *source*), which would silently drop it from git and the npm tarball.
/packages/ui/lib/
**/dist/
storybook-static/

# Expo
.expo/
expo-env.d.ts
# Generated native projects (regenerated by `expo prebuild`)
storybook/native/android/
storybook/native/ios/

# Storybook React Native (generated)
storybook.requires.ts

# Uniwind (generated type declarations for className autocomplete)
uniwind-types.d.ts

# Tests
coverage/

# Misc
*.log
.DS_Store
.env*
!.env.example
