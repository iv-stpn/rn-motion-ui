{
  "name": "@rn-motion-ui/hooks",
  "version": "0.1.0",
  "description": "Reusable React hooks for rn-motion-ui",
  "license": "MIT",
  "author": "Ivan Stepanian <ivanivan1233@gmail.com>",
  "homepage": "https://github.com/iv-stpn/rn-motion-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iv-stpn/rn-motion-ui.git",
    "directory": "packages/hooks"
  },
  "bugs": {
    "url": "https://github.com/iv-stpn/rn-motion-ui/issues"
  },
  "sideEffects": false,
  "exports": {
    "./use-arm-on-view": {
      "source": "./src/use-arm-on-view.ts",
      "types": "./src/use-arm-on-view.ts",
      "default": "./src/use-arm-on-view.ts"
    },
    "./use-hover-capable": {
      "source": "./src/use-hover-capable.ts",
      "types": "./src/use-hover-capable.ts",
      "default": "./src/use-hover-capable.ts"
    },
    "./use-in-view": {
      "source": "./src/use-in-view.ts",
      "types": "./src/use-in-view.ts",
      "default": "./src/use-in-view.ts"
    },
    "./use-interval": {
      "source": "./src/use-interval.ts",
      "types": "./src/use-interval.ts",
      "default": "./src/use-interval.ts"
    },
    "./use-modal-render": {
      "source": "./src/use-modal-render.ts",
      "types": "./src/use-modal-render.ts",
      "default": "./src/use-modal-render.ts"
    },
    "./use-mount-effect": {
      "source": "./src/use-mount-effect.ts",
      "types": "./src/use-mount-effect.ts",
      "default": "./src/use-mount-effect.ts"
    },
    "./use-page-visible": {
      "source": "./src/use-page-visible.ts",
      "types": "./src/use-page-visible.ts",
      "default": "./src/use-page-visible.ts"
    },
    "./use-reduced-motion": {
      "source": "./src/use-reduced-motion.ts",
      "types": "./src/use-reduced-motion.ts",
      "default": "./src/use-reduced-motion.ts"
    },
    "./use-scramble": {
      "source": "./src/use-scramble.ts",
      "types": "./src/use-scramble.ts",
      "default": "./src/use-scramble.ts"
    },
    "./use-shake-animation": {
      "source": "./src/use-shake-animation.ts",
      "types": "./src/use-shake-animation.ts",
      "default": "./src/use-shake-animation.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "@types/react": "19.1.10",
    "react": "19.1.0",
    "react-native": "0.86.0",
    "typescript": "^7"
  }
}
