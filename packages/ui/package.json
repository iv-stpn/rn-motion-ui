  "homepage": "https://github.com/iv-stpn/beui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iv-stpn/beui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/iv-stpn/beui/issues"
  },
  "sideEffects": false,
  "source": "./src/index.ts",
