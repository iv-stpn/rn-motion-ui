{
  "name": "@rn-motion-ui/rn",
  "version": "0.2.0",
  "description": "Animated React Native + React Native Web UI components, styled with Tailwind via uniwind and powered by Moti/Reanimated.",
  "keywords": [
    "react-native",
    "react-native-web",
    "ui",
    "components",
    "moti",
    "reanimated",
