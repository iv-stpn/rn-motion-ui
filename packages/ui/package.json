    "moti": "0.30.0",
    "react": "19.1.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "3.19.5",
    "react-native-web": "0.21.2",
    "storybook": "10.5.0",
